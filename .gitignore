# --- Sensitive or local-only files ---
.gcp/
.env
.env.*
*.env
*.key
*.pem
*.p12
*token*.json
*secret*.json
*service-account*.json
kaggle.json
docs2/

# --- Data files ---
data/
*.parquet
*.tsv
*.xls
*.xlsx
*.db
*.sqlite
*.sqlite3
*.duckdb
*.zip
*.tar
*.tar.gz
*.tgz
*.gz
*.feather
*.rds
*.sas7bdat

# Ignore CSV by default
*.csv

# Allow validation artifacts
!python/outputs/*.csv
!sas/outputs/*.csv

# --- Jupyter ---
.ipynb_checkpoints/
00*.ipynb

# --- Local system files ---
.DS_Store

# --- Python cache ---
__pycache__/
*.pyc

# --- Virtual environments ---
.venv/
venv/

# --- VS Code ---
.vscode/

# --- SAS ---
sas/logs/
sas/data/
sas/outputs/*.html
sas/outputs/*.rtf
*.log
*.lst
*.sas7bcat

# Sensitive/local SAS inputs
sas/inputs/*.csv

# Keep SAS programs tracked
!sas/programs/*.sas

# Keep SAS documentation tracked
!sas/docs/*.md

# Optional:
# Ignore PDFs by default
*.pdf

# If you later want to track selected PDFs:
# !sas/outputs/*.pdf
